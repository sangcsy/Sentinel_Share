# AWS 배포 후 실제 엔드포인트로 채워넣기.
# 로컬 개발 시: VULNERABLE_API_URL=http://localhost:3000 으로 설정하면 로컬 백엔드 대상으로 공격 가능.

# ─── 취약 AWS 환경 ────────────────────────────────────────────
# ECS 직접 노출 (Security Group 0.0.0.0/0, WAF 없음)
VULNERABLE_API_URL=http://your-vulnerable-ecs-ip-or-alb.ap-northeast-2.elb.amazonaws.com

# S3: Block Public Access OFF, 버킷 정책 없음
VULNERABLE_S3_BUCKET=your-vulnerable-bucket-name

# ─── 보안 AWS 환경 ────────────────────────────────────────────
# CloudFront + WAF 앞단에 위치
AWS_API_URL=https://xxxxxxxxxxxx.cloudfront.net

# S3: Block Public Access ON, presigned URL만 허용
AWS_S3_BUCKET=your-secure-bucket-name

# ─── 공통 ─────────────────────────────────────────────────────
AWS_REGION=ap-northeast-2
