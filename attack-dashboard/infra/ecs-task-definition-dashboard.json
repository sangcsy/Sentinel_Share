{
  "family": "cloudshield-dashboard",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::833453046706:role/cloudshield-dashboard-execution-role",
  "taskRoleArn": "arn:aws:iam::833453046706:role/cloudshield-dashboard-task-role",
  "containerDefinitions": [
    {
      "name": "cloudshield-dashboard",
      "image": "833453046706.dkr.ecr.ap-northeast-2.amazonaws.com/cloudshield-dashboard:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "hostPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "AWS_REGION",
          "value": "ap-northeast-2"
        },
        {
          "name": "NODE_ENV",
          "value": "production"
        }
      ],
      "secrets": [
        {
          "name": "VULNERABLE_API_URL",
          "valueFrom": "cloudshield/dashboard/vulnerable-api-url"
        },
        {
          "name": "VULNERABLE_S3_BUCKET",
          "valueFrom": "cloudshield/dashboard/vulnerable-s3-bucket"
        },
        {
          "name": "AWS_API_URL",
          "valueFrom": "cloudshield/dashboard/aws-api-url"
        },
        {
          "name": "AWS_S3_BUCKET",
          "valueFrom": "cloudshield/dashboard/aws-s3-bucket"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/cloudshield-dashboard",
          "awslogs-region": "ap-northeast-2",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "wget -qO- http://localhost:3000/api/config || exit 1"],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 15
      }
    }
  ]
}
