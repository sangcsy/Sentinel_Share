# 프로덕션 배포 참조용 — AWS ECS/Secrets Manager 설정 시 필요한 환경변수 목록.
# 실제 값은 코드/파일에 두지 않고 Secrets Manager → ECS 태스크에 주입.
# 로컬 개발은 .env.local.example 사용.

# Application
NODE_ENV=production
PORT=3000

# JWT
JWT_SECRET=replace-with-strong-random-secret
JWT_EXPIRES_IN=1h

# PostgreSQL (AWS RDS)
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=5432
DB_NAME=sentinelshare
DB_USER=sentinelshare_user
DB_PASSWORD=replace-with-strong-password

# AWS S3
AWS_REGION=ap-northeast-2
S3_BUCKET_NAME=your-sentinelshare-bucket

# Presigned URL TTL (seconds)
PRESIGNED_URL_TTL=300

# File upload limits
MAX_FILE_SIZE_MB=100
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf,text/plain,application/zip,application/x-zip-compressed

# CORS
CORS_ORIGIN=https://your-frontend-domain.com
