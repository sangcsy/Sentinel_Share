# 로컬 개발용 — Docker Compose(PostgreSQL) + LocalStack(S3) 환경에서 동작하는 실제 값.
# cp .env.local.example .env 후 npm run dev 로 바로 실행 가능.
# 프로덕션 배포 참조는 .env.example 사용.

NODE_ENV=development
PORT=3000

# JWT
JWT_SECRET=local-dev-secret-do-not-use-in-production
JWT_EXPIRES_IN=1h

# PostgreSQL (Docker)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sentinelshare
DB_USER=sentinelshare_user
DB_PASSWORD=localpassword

# AWS (LocalStack)
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_ENDPOINT_URL=http://localhost:4566
S3_BUCKET_NAME=sentinelshare-local

# Presigned URL TTL (seconds)
PRESIGNED_URL_TTL=300

# File limits
MAX_FILE_SIZE_MB=100
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf,text/plain,application/zip,application/x-zip-compressed

# CORS
CORS_ORIGIN=http://localhost:3001,http://localhost:3002
